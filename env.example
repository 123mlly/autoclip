# AutoClip 环境变量配置示例
# 复制此文件为 .env 并填入实际配置

# 数据库配置
DATABASE_URL=sqlite:///./data/autoclip.db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Whisper 设备（可选）：auto | cpu | cuda | cuda:0
# Docker GPU 模式默认 auto；强制 CPU 可设 WHISPER_DEVICE=cpu
# WHISPER_DEVICE=auto

# 语音识别：faster_whisper（推荐）| sensevoice | whisper_local
SPEECH_RECOGNITION_METHOD=faster_whisper
SPEECH_RECOGNITION_LANGUAGE=auto
SPEECH_RECOGNITION_MODEL=base
# CPU 默认 int8；GPU 可用 float16
# FASTER_WHISPER_COMPUTE_TYPE=int8
# FASTER_WHISPER_DEVICE=cpu
# SenseVoice 备用：
# SPEECH_RECOGNITION_METHOD=sensevoice
# SPEECH_RECOGNITION_MODEL=iic/SenseVoiceSmall
# SENSEVOICE_DEVICE=cpu

# API配置
API_DASHSCOPE_API_KEY=your_dashscope_api_key_here
API_MODEL_NAME=qwen3.7-plus
# 可选：国际站改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_MAX_TOKENS=4096
API_TIMEOUT=30

# 处理配置
PROCESSING_CHUNK_SIZE=5000
PROCESSING_MIN_SCORE_THRESHOLD=0.7
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
PROCESSING_MAX_RETRIES=3

# 路径配置（可选，系统会自动检测）
# PATH_PROJECT_ROOT=
# PATH_DATA_DIR=
# PATH_UPLOADS_DIR=
# PATH_TEMP_DIR=
# PATH_OUTPUT_DIR=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=backend.log

# 环境配置
ENVIRONMENT=development
DEBUG=true

# 加密密钥（绑 B 站/YouTube 账号时建议设置，否则 cookies/凭据加密不稳定）
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# YouTube 投稿（Google Cloud OAuth）
# 在 https://console.cloud.google.com/ 创建 OAuth 客户端后填入
# 授权重定向 URI 需包含: http://localhost:8000/api/v1/youtube-upload/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube-upload/oauth/callback
 